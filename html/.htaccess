RewriteEngine On
# redirect from www. to
RewriteCond %{HTTP_HOST} ^www\.vitrazeart\.cz [NC]
RewriteRule ^(.*)$ https://vitrazeart.cz/$1 [L,R=301]
# actual files and folders without redirection
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
# redirect page/file to php page
RewriteRule ^feed\.xml$ feed.php [L]
RewriteRule ^sitemap\.xml$ sitemap.php [L]
RewriteRule ^about(/.*)?$ pages.php [L]
RewriteRule ^search(/.*)?$ search.php [L]
RewriteRule ^events(/.*)?$ events.php [L]
RewriteRule ^reports(/.*)?$ reports.php [L]
RewriteRule ^authors(/.*)?$ authors.php [L]
RewriteRule ^gallery(/.*)?$ gallery.php [L]
RewriteRule ^@.*$ authors.php [L]